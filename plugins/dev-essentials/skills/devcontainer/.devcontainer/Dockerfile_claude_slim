# syntax=docker/dockerfile:1.7

FROM python:3.13-slim

ARG NODE_MAJOR=24

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive \
  PIP_DISABLE_PIP_VERSION_CHECK=1 \
  PIP_NO_CACHE_DIR=1 \
  PIP_ROOT_USER_ACTION=ignore \
  PYTHONDONTWRITEBYTECODE=1 \
  PYTHONUNBUFFERED=1 \
  TERM=xterm-256color \
  COLORTERM=truecolor

# essitial + terminal tools to make agents efficient.
RUN set -eux; \
  apt-get update && apt-get install -y --no-install-recommends \
  git \
  ripgrep \
  curl \
  wget \
  gpg \
  jq \
  fd-find \
  tree \
  make \
  patch \
  sqlite3 \
  unzip \
  zip \
  procps \
  file \
  vim \
  && ln -s /usr/bin/fdfind /usr/local/bin/fd \
  && rm -rf /var/lib/apt/lists/*


RUN set -eux; \
  if ! getent group devcontainer >/dev/null; then groupadd --gid 2001 devcontainer; fi; \
  if ! id --user devcontainer >/dev/null 2>&1; then \
    useradd --uid 2001 --gid 2001 --create-home --shell /bin/bash devcontainer; \
  fi

RUN set -eux; \
  mkdir -p /etc/apt/keyrings \
  && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
     | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
  && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
     | tee /etc/apt/sources.list.d/nodesource.list \
  && apt-get update && apt-get install -y --no-install-recommends nodejs \
  && rm -rf /var/lib/apt/lists/* \
  && npm config set --global strict-ssl true \
  && npm config set --global registry https://registry.npmjs.org/ \
  && npm config set --global audit true \
  && npm config set --global update-notifier false \
  && npm config set --global fund false \
  && npm install -g pnpm@11.5.3

USER devcontainer

ENV PNPM_HOME=/home/devcontainer/.local/share/pnpm
ENV PATH="/home/devcontainer/.local/share/pnpm/bin:/home/devcontainer/.local/bin:${PATH}"

# Explicit version pin as supply-chain guard.
RUN pip install --user uv==0.7.13

# 7-day release age supply chain guard - 7*24*60 = 10080 minutes
RUN set -eux; \
  pnpm config set minimumReleaseAge 10080 \
  && pnpm add -g \
     --allow-build=@anthropic-ai/claude-code \
     @anthropic-ai/claude-code \
  && claude --version

WORKDIR /workspaces
